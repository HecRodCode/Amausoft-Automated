# =========================
# CORE
# =========================
PYTHONPATH=/opt/pipelines
AIRFLOW_UID=50000

# =========================
# WORKER CONFIG
# =========================
CELERY_HOSTNAME=<WORKER_NAME>
QUEUES=default

# =========================
# AIRFLOW CORE
# =========================
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=vBPzgsn5RQSVzOgcMO_RS3zQXSt3WSZpM8eSqOV6MLc=
AIRFLOW__CORE__DAGS_FOLDER=/opt/pipelines/dags
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false

# =========================
# DATABASE
# =========================
DB_USER=user
DB_PASSWORD=password
DB_HOST=host
DB_NAME=database_name
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://user:password@host/database_name

# =========================
# RabbitMQ
# =========================
RABBIT_USER=user_rabbit
RABBIT_PASSWORD=password_rabbit
RABBITMQ_DEFAULT_USER=user_rabbit
RABBITMQ_DEFAULT_PASS=password_rabbit

# =========================
# CELERY
# =========================
AIRFLOW__CELERY__BROKER_URL=amqp://user:passowrd@ip_host:5672/
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://user:password@host/database_name

# =========================
# API / WEB
# =========================
AIRFLOW__API__BASE_URL=http://ip_host:8080
AIRFLOW__API__INSTANCE_NAME=Airflow Data Platform
AIRFLOW__API__SECRET_KEY=your_secretKey
AIRFLOW__API__SERVER_TYPE=gunicorn
AIRFLOW__API_AUTH__JWT_SECRET=JWT_secret
AIRFLOW__API_AUTH__JWT_ISSUER=http://ip_host/execution/
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://ip_host/execution/

# =========================
# SCHEDULER
# =========================
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=300

# =========================
# CLI / INIT
# =========================
_AIRFLOW_DB_MIGRATE=true
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
